<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TarotDesk.AddDeckPage"
    Title="Thêm bộ bài"
    BackgroundColor="#1a0a2e">

    <ContentPage.Background>
        <StaticResource Key="StarfieldBrush" />
    </ContentPage.Background>

    <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="FillAndExpand" HorizontalOptions="Fill">

        <Label 
            Text="✦ Thêm bộ bài mới"
            FontSize="24"
            FontAttributes="Bold"
            TextColor="#FFFFFF" />

        <Entry 
            x:Name="DeckNameEntry"
            Placeholder="Nhập tên bộ bài"
            TextColor="#ffffff"
            PlaceholderColor="#a8a8a8"
            BackgroundColor="#2D1B4E50" />

        <Button 
            Text="♠ Thêm lá bài"
            Clicked="OnAddCardClicked"
            Style="{StaticResource GlassButton}"
            BackgroundColor="#512DA820" />

        <CollectionView 
            x:Name="CardsCollectionView"
            SelectionMode="None"
            VerticalOptions="FillAndExpand">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout 
                    Orientation="Vertical"
                    ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout 
                        Padding="10"
                        BackgroundColor="#2D1B4E80">
                        <Label 
                            Text="{Binding Name}"
                            FontAttributes="Bold"
                            TextColor="#FFFFFF"
                            FontSize="14" />
                        <Label 
                            Text="{Binding Meaning}"
                            TextColor="#FFFFFF"
                            FontSize="11" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button 
            Text="◆ Lưu bộ bài"
            Clicked="OnSaveDeckClicked"
            Style="{StaticResource GlassButton}"
            BackgroundColor="#4A148C20" />

    </VerticalStackLayout>

</ContentPage>
