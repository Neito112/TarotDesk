<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TarotDesk.SelectDeckPage"
    Title="Chọn bộ bài"
    BackgroundColor="#1a0a2e">

    <ContentPage.Background>
        <StaticResource Key="StarfieldBrush" />
    </ContentPage.Background>

    <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="FillAndExpand">

        <Label 
            Text="◆ Chọn bộ bài để trải"
            FontSize="24"
            FontAttributes="Bold"
            TextColor="#FFFFFF" />

        <ActivityIndicator
            x:Name="LoadingIndicator"
            IsRunning="False"
            IsVisible="False"
            Color="#ffe082" />

        <!-- Empty state with full height -->
        <VerticalStackLayout 
            x:Name="EmptyStateContainer"
            VerticalOptions="FillAndExpand"
            HorizontalOptions="Fill"
            Spacing="20"
            Padding="20">
            <Label 
                x:Name="NoDecksLabel"
                Text="Chưa có bộ bài nào. Hãy tạo bộ bài trước!"
                IsVisible="False"
                TextColor="#FFFFFF"
                FontSize="16"
                HorizontalTextAlignment="Center"
                VerticalOptions="CenterAndExpand" />
        </VerticalStackLayout>

        <!-- CollectionView with decks -->
        <CollectionView 
            x:Name="DecksCollectionView"
            SelectionMode="Single"
            SelectionChangedCommand="{Binding SelectCommand}"
            VerticalOptions="FillAndExpand">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout 
                    Orientation="Vertical"
                    ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border 
                        Padding="15"
                        BackgroundColor="#2D1B4E80"
                        Stroke="#FFFFFF20"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>
                        <VerticalStackLayout 
                            Spacing="5">
                        <Label 
                            Text="{Binding Name}"
                            FontAttributes="Bold"
                            TextColor="#FFFFFF"
                            FontSize="16" />
                        <Label 
                            Text="{Binding CardCountText}"
                            TextColor="#FFFFFF"
                            FontSize="12" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
