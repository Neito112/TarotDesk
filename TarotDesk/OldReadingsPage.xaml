<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TarotDesk.OldReadingsPage"
    Title="Lịch sử trải bài"
    BackgroundColor="#1a0a2e">

    <ContentPage.Background>
        <StaticResource Key="StarfieldBrush" />
    </ContentPage.Background>

    <VerticalStackLayout Padding="15" Spacing="10" VerticalOptions="FillAndExpand">

        <Label 
            Text="◆ Lịch sử các lưới trải"
            FontSize="24"
            FontAttributes="Bold"
            TextColor="#FFFFFF" />

        <ActivityIndicator
            x:Name="LoadingIndicator"
            IsRunning="False"
            IsVisible="False"
            Color="#FFFFFF" />

        <!-- Empty state with full height -->
        <VerticalStackLayout 
            x:Name="EmptyStateContainer"
            VerticalOptions="FillAndExpand"
            HorizontalOptions="Fill"
            Spacing="20"
            Padding="20">
            <Label 
                x:Name="NoReadingsLabel"
                Text="Chưa có lưới trải bài nào!"
                IsVisible="False"
                TextColor="#ffe082"
                FontSize="16"
                HorizontalTextAlignment="Center"
                VerticalOptions="CenterAndExpand" />
        </VerticalStackLayout>

        <!-- CollectionView with readings -->
        <CollectionView 
            x:Name="ReadingsCollectionView"
            SelectionMode="Single"
            VerticalOptions="FillAndExpand">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout 
                    Orientation="Vertical"
                    ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border 
                        Padding="15"
                        BackgroundColor="#2D1B4E80"
                        Stroke="#FFFFFF20"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>
                        <Grid 
                            ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Index -->
                        <Label 
                            Grid.Column="0"
                            Text="{Binding Id}"
                            TextColor="#FFFFFF"
                            FontSize="14"
                            FontAttributes="Bold"
                            VerticalOptions="Center" />

                        <!-- Name and Date -->
                        <VerticalStackLayout 
                            Grid.Column="1"
                            Spacing="3">
                            <Label 
                                Text="{Binding Name}"
                                TextColor="#FFFFFF"
                                FontSize="16"
                                FontAttributes="Bold" />
                            <Label 
                                Text="{Binding DateText}"
                                TextColor="#FFFFFF"
                                FontSize="12" />
                        </VerticalStackLayout>

                        <!-- Card count -->
                        <Label 
                            Grid.Column="2"
                            Text="{Binding CardCountText}"
                            TextColor="#FFFFFF"
                            FontSize="12"
                            VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
